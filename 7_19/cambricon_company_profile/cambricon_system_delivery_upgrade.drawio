        <mxCell id="software" value="集群管理软件：资源调度、任务运行与运维管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAFBF2;strokeColor=#65B78B;fontColor=#0A6B40;fontSize=16;fontStyle=1;fontFamily=Microsoft YaHei;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1070" y="600" width="450" height="70" as="geometry"/></mxCell>
        <mxCell id="edge4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#3E8D62;strokeWidth=3;" edge="1" parent="1" source="software" target="cluster"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="value" value="客户价值：从采购单点部件，走向获取可交付的智算基础设施" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF6E8;strokeColor=#F0B95D;fontColor=#9A5A00;fontSize=17;fontStyle=1;fontFamily=Microsoft YaHei;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="270" y="755" width="980" height="70" as="geometry"/></mxCell>
        <mxCell id="note" value="注：图示为产品交付形态的概念化演进，合作伙伴可提供服务器、网络与存储等组成部分。" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontColor=#64748B;fontFamily=Microsoft YaHei;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="72" y="850" width="1100" height="26" as="geometry"/></mxCell>
