        <mxCell id="title" value="从卖芯片到系统级交付" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontStyle=1;fontColor=#15233D;fontFamily=Microsoft YaHei;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="70" y="48" width="720" height="52" as="geometry"/></mxCell>
        <mxCell id="subtitle" value="寒武纪智能计算集群系统：产品形态与客户交付范围逐步扩展" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontColor=#64748B;fontFamily=Microsoft YaHei;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="72" y="105" width="980" height="30" as="geometry"/></mxCell>
        <mxCell id="complexity" value="系统集成与交付复杂度 ↑" style="text;html=1;align=right;verticalAlign=middle;fontSize=15;fontColor=#64748B;fontFamily=Microsoft YaHei;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1030" y="150" width="380" height="32" as="geometry"/></mxCell>
        <mxCell id="chip" value="&lt;b&gt;1. AI 芯片&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#64748B&quot;&gt;思元系列&lt;/font&gt;&lt;br&gt;单颗核心计算器件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#8BB7F0;strokeWidth=2;fontColor=#15233D;fontSize=17;fontFamily=Microsoft YaHei;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="80" y="290" width="280" height="180" as="geometry"/></mxCell>
        <mxCell id="card" value="&lt;b&gt;2. AI 加速卡&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#64748B&quot;&gt;例如 MLU370-X8&lt;/font&gt;&lt;br&gt;可插入服务器的加速部件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDEBFF;strokeColor=#649AE5;strokeWidth=2;fontColor=#15233D;fontSize=17;fontFamily=Microsoft YaHei;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="435" y="290" width="280" height="180" as="geometry"/></mxCell>
        <mxCell id="server" value="&lt;b&gt;3. 整机服务器&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#64748B&quot;&gt;思元芯片 + 服务器&lt;/font&gt;&lt;br&gt;面向部署的一体化方案" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBD8FF;strokeColor=#3E7FD6;strokeWidth=2;fontColor=#15233D;fontSize=17;fontFamily=Microsoft YaHei;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="790" y="290" width="280" height="180" as="geometry"/></mxCell>
        <mxCell id="cluster" value="&lt;b&gt;4. 智能计算集群&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#E5EEFF&quot;&gt;芯片 + 板卡 + 服务器 + 网络 + 存储 + 管理软件&lt;/font&gt;&lt;br&gt;可部署、可管理、可运行的整体方案" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1C5FC5;strokeColor=#0D3E8A;strokeWidth=2;fontColor=#FFFFFF;fontSize=17;fontFamily=Microsoft YaHei;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1145" y="270" width="330" height="220" as="geometry"/></mxCell>
