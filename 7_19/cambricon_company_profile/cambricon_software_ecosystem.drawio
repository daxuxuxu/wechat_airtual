        <mxCell id="hardware" value="&lt;b&gt;硬件基座&lt;/b&gt;&lt;br&gt;智能处理器 IP（Cambricon-1M / 1H） ｜ 思元芯片（370 / 270 / 220） ｜ AI 加速卡与整机（MLU 系列）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#5C96FF;strokeWidth=2;fontColor=#15233D;fontSize=18;fontFamily=Microsoft YaHei;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="220" y="605" width="1000" height="112" as="geometry"/></mxCell>
