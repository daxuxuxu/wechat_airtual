        <mxCell id="software" value="&lt;b&gt;软件生态层&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#0A6B40&quot;&gt;Cambricon NeuWare&lt;/span&gt; ｜ &lt;span style=&quot;color:#0A6B40&quot;&gt;MagicMind&lt;/span&gt; ｜ 编译器 ｜ 开发者工具 ｜ 集群管理软件&lt;br&gt;&lt;font color=&quot;#64748B&quot;&gt;负责模型迁移、开发调试、运行优化与资源管理&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAFBF2;strokeColor=#65B78B;strokeWidth=2;fontColor=#15233D;fontSize=18;fontFamily=Microsoft YaHei;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="220" y="385" width="1000" height="135" as="geometry"/></mxCell>
