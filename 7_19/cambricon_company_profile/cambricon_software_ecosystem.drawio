        <mxCell id="title" value="寒武纪产品技术栈与软件生态" style="text;html=1;align=left;verticalAlign=middle;fontSize=28;fontStyle=1;fontColor=#15233D;fontFamily=Microsoft YaHei;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="70" y="48" width="750" height="52" as="geometry"/></mxCell>
        <mxCell id="subtitle" value="从芯片 IP 到集群软件：软件层决定硬件能否更易部署、开发与管理" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontColor=#64748B;fontFamily=Microsoft YaHei;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="72" y="105" width="1050" height="30" as="geometry"/></mxCell>
        <mxCell id="purpose" value="目标：让硬件更“好用”、更容易适配模型与规模化交付" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF6E8;strokeColor=#F0B95D;fontColor=#9A5A00;fontSize=16;fontStyle=1;fontFamily=Microsoft YaHei;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1030" y="70" width="410" height="60" as="geometry"/></mxCell>
        <mxCell id="app" value="&lt;b&gt;最终应用&lt;/b&gt;&lt;br&gt;大模型训练与推理｜图像识别｜自然语言处理｜智能终端" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7D6;strokeColor=#E8C65A;fontColor=#5F4B00;fontSize=18;fontFamily=Microsoft YaHei;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="320" y="200" width="800" height="105" as="geometry"/></mxCell>
