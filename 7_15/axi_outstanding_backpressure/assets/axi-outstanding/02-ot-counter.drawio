      <mxGeometry x="55" y="90" width="420" height="195" as="geometry"/>
    </mxCell>
    <mxCell id="4" value="alloc = aw_fire + ar_fire&#xa;retire = b_fire + r_last_fire&#xa;ot_count_next = ot_count + alloc - retire" style="rounded=1;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;fillColor=#FFFFFF;strokeColor=#1F6FB5;strokeWidth=2;fontSize=16;fontColor=#17324D;" vertex="1" parent="3">
      <mxGeometry x="30" y="65" width="360" height="95" as="geometry"/>
    </mxCell>
    <mxCell id="5" value="Allocate only&#xa;alloc=1, retire=0&#xa;N → N+1" style="rounded=1;html=1;whiteSpace=wrap;align=center;fillColor=#EAF3FF;strokeColor=#1F6FB5;strokeWidth=2;shadow=1;fontColor=#17324D;" vertex="1" parent="1">
      <mxGeometry x="535" y="90" width="180" height="105" as="geometry"/>
    </mxCell>
    <mxCell id="6" value="Retire only&#xa;alloc=0, retire=1&#xa;N → N-1" style="rounded=1;html=1;whiteSpace=wrap;align=center;fillColor=#E9F7EC;strokeColor=#5D9E5D;strokeWidth=2;shadow=1;fontColor=#17324D;" vertex="1" parent="1">
      <mxGeometry x="760" y="90" width="180" height="105" as="geometry"/>
    </mxCell>
    <mxCell id="7" value="No event&#xa;alloc=0, retire=0&#xa;N → N" style="rounded=1;html=1;whiteSpace=wrap;align=center;fillColor=#F2F4F5;strokeColor=#5D6D7E;strokeWidth=2;shadow=1;fontColor=#34495E;" vertex="1" parent="1">
      <mxGeometry x="535" y="250" width="180" height="105" as="geometry"/>
    </mxCell>
    <mxCell id="8" value="Same cycle&#xa;alloc=1, retire=1&#xa;N → N" style="rounded=1;html=1;whiteSpace=wrap;align=center;fillColor=#FFF4E5;strokeColor=#E67E22;strokeWidth=2.5;shadow=1;fontColor=#8A4300;" vertex="1" parent="1">
      <mxGeometry x="760" y="250" width="180" height="105" as="geometry"/>
    </mxCell>
    <mxCell id="9" value="AWVALID &amp;&amp; AWREADY&#xa;or ARVALID &amp;&amp; ARREADY" style="rounded=1;html=1;whiteSpace=wrap;align=center;fillColor=#FFFFFF;strokeColor=#1F6FB5;strokeWidth=2;fontColor=#17324D;" vertex="1" parent="1">
