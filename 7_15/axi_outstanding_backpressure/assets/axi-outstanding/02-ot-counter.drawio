    <mxCell id="11" value="allocation" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1F6FB5;strokeWidth=2.5;endArrow=block;endFill=1;fontColor=#1F6FB5;" edge="1" parent="1" source="9" target="4">
