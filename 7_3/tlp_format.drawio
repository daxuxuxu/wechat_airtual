    </mxCell>
    <mxCell id="note_len" value="Length：DW 数（1~1024）&#xa;受 MPS 约束，不超过 MPS/4" style="text;html=1;align=center;fontSize=9;fontColor=#1565C0;fontStyle=2;" vertex="1" parent="1">
