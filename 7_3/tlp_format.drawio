    </mxCell>

    <mxCell id="rule" value="PCIe 规范约束：单笔 Memory Write TLP 数据 ≤ MPS，且不得跨越 4KB 自然对齐边界" style="rounded=1;arcSize=4;fillColor=#FFF8E1;strokeColor=#FFB300;fontColor=#E65100;fontSize=10;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
